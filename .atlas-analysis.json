  "keyFeatures": [
    "Multi-courier rate quoting for Africa (economy, standard, express, same-day, overnight)",
    "Order creation and fulfilment with last-mile or station-pickup delivery methods",
    "Direct shipment creation bypassing the order layer",
    "Real-time shipment tracking and status events",
    "Proof of delivery capture (photo, OTP, signature)",
    "Returns and exchanges lifecycle management",
    "Webhook subscriptions with HMAC-SHA256 signature verification",
    "Sandbox (test) environment fully isolated from production",
    "Idempotency support on all write requests",
    "Auto-retry with exponential backoff built into the TypeScript SDK"
  ],
  "publicApiSurface": [
    "POST /v1/rates/calculate",
    "GET /v1/rates/zones",
    "POST /v1/orders",

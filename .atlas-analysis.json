    "POST /v1/orders/{orderId}/fulfil-on-demand",
    "POST /v1/shipments",
    "GET /v1/shipments/{shipmentId}",
    "POST /v1/shipments/{shipmentId}/cancel",
    "GET /v1/tracking/{trackingNumber}",
    "GET /v1/shipments/{shipmentId}/tracking",
    "GET /v1/pod/{shipmentId}",
    "POST /v1/returns",
    "GET /v1/returns",
    "GET /v1/returns/{returnId}",
    "POST /v1/returns/{returnId}/approve",
    "POST /v1/returns/{returnId}/reject",
    "POST /v1/returns/{returnId}/receive",
    "POST /v1/returns/{returnId}/resolve",
    "POST /v1/webhooks",
    "GET /v1/webhooks",
    "DELETE /v1/webhooks/{webhookId}",
    "POST /v1/webhooks/{webhookId}/test",
    "GET /v1/health",
    "TLDP client class (TypeScript SDK)",
    "OrdersService: createOrder, getOrder, updateOrder, cancelOrder, fulfilOrder, onDemandQuote, fulfilOrderOnDemand",
    "ShipmentsService: createShipment, getShipment, cancelShipment",
    "RatesService: calculateRates, listZones",
    "TrackingService: trackShipment, getShipmentTracking",
    "ProofOfDeliveryService: getProofOfDelivery",
    "ReturnsService: requestReturn, getReturn, approveReturn, rejectReturn, receiveReturn, resolveReturn",
    "WebhooksService: createWebhook, listWebhooks, deleteWebhook, testWebhook",
    "SystemService: getApiInfo, getHealth"
  ]
